{
  "expo": {
    "name": "GrindRoom",
    "slug": "grindroom",
    "version": "1.0.0",
    "versionCode": 1,
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "grindroom",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0e0e0e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pratscodes8.grindroom"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0e0e0e"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.pratscodes8.grindroom",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f24aa01e-845d-4bf8-a262-b285957a318a"
      }
    },
    "owner": "pratscodes8"
  }
}
